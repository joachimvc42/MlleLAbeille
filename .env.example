# ============================================================================
# MlleLAbeille — variables d'environnement
#
# Copier ce fichier en `.env.local` (jamais commité) et remplir au fur et
# à mesure. TOUT est optionnel : sans aucune clé, le site tourne en mode
# démo complet (catalogue local, panier localStorage, checkout étiqueté
# « démo », newsletter/contact acquittés sans stockage).
#
# Sur Vercel : Project Settings → Environment Variables (docs/DEPLOYMENT.md).
# ============================================================================

# ----------------------------------------------------------------------------
# Site — URL publique canonique (SEO, sitemap, redirections checkout).
# À renseigner dès le premier déploiement, puis remplacer par le domaine final.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://mllelabeille.vercel.app

# ----------------------------------------------------------------------------
# Supabase — base de données, auth, storage (supabase/README.md).
# Project Settings → API. Exécuter les 4 SQL : schema → rls → storage → seed.
# La clé service_role est STRICTEMENT serveur : jamais de préfixe NEXT_PUBLIC_.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------------------
# Stripe — paiement (docs/DEPLOYMENT.md §2).
# Clé secrète (sk_test_… puis sk_live_…). Webhook à créer dans le dashboard :
#   URL      : {NEXT_PUBLIC_SITE_URL}/api/webhooks/stripe
#   Événement: checkout.session.completed
# Le « Signing secret » (whsec_…) du webhook va dans STRIPE_WEBHOOK_SECRET.
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# Printify — impression à la demande (docs/PRINTIFY.md).
# Token : My profile → Connections → API tokens.
# Shop id : GET https://api.printify.com/v1/shops.json
# Webhook (optionnel mais recommandé) :
#   URL       : {NEXT_PUBLIC_SITE_URL}/api/webhooks/printify
#   Événements: order:shipment:created, order:shipment:delivered
#   Secret    : le même que PRINTIFY_WEBHOOK_SECRET (signature X-Pfy-Signature)
# ----------------------------------------------------------------------------
PRINTIFY_API_TOKEN=
PRINTIFY_SHOP_ID=
PRINTIFY_WEBHOOK_SECRET=
